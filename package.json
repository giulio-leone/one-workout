{
  "name": "@giulio-leone/one-workout",
  "version": "0.2.0",
  "description": "OneWorkout - Unified Workout Domain for OneCoach",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./program-transform": {
      "types": "./src/core/transformers/program-transform.ts",
      "default": "./src/core/transformers/program-transform.ts"
    },
    "./program-server-transform": {
      "types": "./src/core/transformers/program-server-transform.ts",
      "default": "./src/core/transformers/program-server-transform.ts"
    },
    "./normalizers/workout-normalizer": {
      "types": "./src/core/normalizers/workout-normalizer.ts",
      "default": "./src/core/normalizers/workout-normalizer.ts"
    },
    "./weight-calculator": {
      "types": "./src/core/calculators/weight-calculator.ts",
      "default": "./src/core/calculators/weight-calculator.ts"
    },
    "./workout-weight-calculator.service": {
      "types": "./src/core/workout-weight-calculator.service.ts",
      "default": "./src/core/workout-weight-calculator.service.ts"
    },
    "./utils/progression-calculator": {
      "types": "./src/core/calculators/progression-calculator.ts",
      "default": "./src/core/calculators/progression-calculator.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@giulio-leone/contracts": "workspace:*",
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/lib-exercise": "workspace:*",
    "@giulio-leone/lib-import-core": "workspace:*",
    "@giulio-leone/lib-metadata": "workspace:*",
    "@giulio-leone/lib-shared": "workspace:*",
    "@giulio-leone/one-agent": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "@giulio-leone/types": "workspace:*",
    "ai": "6.0.77",
    "xlsx": "^0.18.5",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@prisma/client": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "sideEffects": false
}

{
  "id": "exercise-generation",
  "version": "2.1.0",
  "type": "agent",
  "description": "Generates exercises based on description and criteria",
  "interface": {
    "input": { "$ref": "./schema.ts#ExerciseGenerationInputSchema" },
    "output": { "$ref": "./schema.ts#ExerciseGenerationOutputSchema" }
  },
  "mcpServers": {},
  "skills": {
    "path": "skills",
    "expose": []
  },
  "tools": {
    "source": "registry",
    "allowlist": []
  },
  "progress": {
    "aiDriven": true,
    "fallbackSteps": [
      { "name": "parsing-input", "weight": 10 },
      { "name": "generating-exercises", "weight": 70 },
      { "name": "formatting-output", "weight": 20 }
    ]
  },
  "config": {
    "tier": "balanced",
    "temperature": 1,
    "maxSteps": 10,
    "maxTokens": 8192,
    "timeout": 120000,
    "executionMode": "durable",
    "skipSynthesis": true,
    "outputArtifact": "exercises",
    "durability": {
      "enabled": true,
      "maxDurationMs": 600000,
      "retry": {
        "maxAttempts": 3,
        "backoffMs": 1000,
        "backoffMultiplier": 2
      },
      "checkpointStrategy": "step"
    }
  }
}

{
  "id": "workout-generation",
  "version": "2.1.0",
  "type": "agent",
  "description": "Multi-agent workout program generator using SDK v4.2 with durable execution",
  "interface": {
    "input": { "$ref": "./schema.ts#WorkoutGenerationInputSchema" },
    "output": { "$ref": "./schema.ts#WorkoutGenerationOutputSchema" }
  },
  "mcpServers": {},
  "skills": {
    "path": "skills",
    "expose": []
  },
  "tools": {
    "source": "registry",
    "allowlist": []
  },
  "progress": {
    "aiDriven": false,
    "fallbackSteps": [
      { "name": "parallel-init", "weight": 20 },
      { "name": "progression-calculator", "weight": 15 },
      { "name": "day-generator", "weight": 25 },
      { "name": "merge-exercises", "weight": 5 },
      { "name": "parallel-post", "weight": 25 },
      { "name": "assemble-weeks", "weight": 10 }
    ]
  },
  "config": {
    "tier": "balanced",
    "temperature": 1,
    "maxSteps": 50,
    "maxTokens": 8192,
    "timeout": 600000,
    "executionMode": "durable",
    "skipSynthesis": true,
    "outputArtifact": "finalProgram",
    "durability": {
      "enabled": true,
      "maxDurationMs": 1800000,
      "retry": {
        "maxAttempts": 5,
        "backoffMs": 2000,
        "backoffMultiplier": 2
      },
      "checkpointStrategy": "step"
    }
  }
}

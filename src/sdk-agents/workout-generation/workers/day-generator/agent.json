{
  "id": "day-generator",
  "version": "2.1.0",
  "type": "agent",
  "description": "Generates detailed workout days with sets, reps, and weights",
  "interface": {
    "input": { "$ref": "./schema.ts#DayGeneratorInputSchema" },
    "output": { "$ref": "./schema.ts#DayGeneratorOutputSchema" }
  },
  "skills": {
    "path": "skills",
    "expose": []
  },
  "tools": {
    "source": "registry",
    "allowlist": []
  },
  "progress": {
    "aiDriven": true,
    "fallbackSteps": [
      { "name": "loading-schedule", "weight": 10 },
      { "name": "generating-exercises", "weight": 50 },
      { "name": "calculating-volume", "weight": 30 },
      { "name": "formatting-days", "weight": 10 }
    ]
  },
  "config": {
    "tier": "balanced",
    "temperature": 1,
    "maxSteps": 15,
    "maxTokens": 8192,
    "timeout": 120000,
    "executionMode": "durable",
    "durability": {
      "enabled": true,
      "maxDurationMs": 600000,
      "retry": {
        "maxAttempts": 3,
        "backoffMs": 1000,
        "backoffMultiplier": 2
      },
      "checkpointStrategy": "step"
    }
  }
}

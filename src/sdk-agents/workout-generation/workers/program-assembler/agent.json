{
  "id": "program-assembler",
  "version": "2.1.0",
  "type": "agent",
  "description": "Assembles final workout program with post-processing and metadata",
  "interface": {
    "input": { "$ref": "./schema.ts#ProgramAssemblerInputSchema" },
    "output": { "$ref": "./schema.ts#ProgramAssemblerOutputSchema" }
  },
  "skills": {
    "path": "skills",
    "expose": []
  },
  "tools": {
    "source": "registry",
    "allowlist": []
  },
  "progress": {
    "aiDriven": true,
    "fallbackSteps": [
      { "name": "collecting-artifacts", "weight": 20 },
      { "name": "assembling-program", "weight": 50 },
      { "name": "adding-metadata", "weight": 30 }
    ]
  },
  "config": {
    "tier": "balanced",
    "temperature": 1,
    "maxSteps": 10,
    "maxTokens": 8192,
    "timeout": 120000,
    "executionMode": "durable",
    "durability": {
      "enabled": true,
      "maxDurationMs": 600000,
      "retry": {
        "maxAttempts": 3,
        "backoffMs": 1000,
        "backoffMultiplier": 2
      },
      "checkpointStrategy": "step"
    }
  }
}

{
  "id": "progression-calculator",
  "version": "2.1.0",
  "type": "agent",
  "description": "Calculates week-to-week progression matrix",
  "interface": {
    "input": { "$ref": "./schema.ts#ProgressionCalculatorInputSchema" },
    "output": { "$ref": "./schema.ts#ProgressionCalculatorOutputSchema" }
  },
  "skills": {
    "path": "skills",
    "expose": []
  },
  "tools": {
    "source": "registry",
    "allowlist": []
  },
  "progress": {
    "aiDriven": true,
    "fallbackSteps": [
      { "name": "analyzing-schedule", "weight": 20 },
      { "name": "calculating-progression", "weight": 60 },
      { "name": "formatting-matrix", "weight": 20 }
    ]
  },
  "config": {
    "tier": "balanced",
    "temperature": 1,
    "maxSteps": 15,
    "maxTokens": 8192,
    "timeout": 120000,
    "executionMode": "durable",
    "durability": {
      "enabled": true,
      "maxDurationMs": 600000,
      "retry": {
        "maxAttempts": 3,
        "backoffMs": 1000,
        "backoffMultiplier": 2
      },
      "checkpointStrategy": "step"
    }
  }
}

{
  "id": "progression-diff-generator",
  "version": "2.1.0",
  "type": "agent",
  "description": "Generates progression diffs for weeks 2-4 based on Week 1 template",
  "interface": {
    "input": { "$ref": "./schema.ts#ProgressionDiffGeneratorInputSchema" },
    "output": { "$ref": "./schema.ts#ProgressionDiffGeneratorOutputSchema" }
  },
  "mcpServers": {},
  "skills": {
    "path": "skills",
    "expose": []
  },
  "tools": {
    "source": "registry",
    "allowlist": []
  },
  "progress": {
    "aiDriven": true,
    "fallbackSteps": [
      { "name": "analyzing-week1", "weight": 20 },
      { "name": "generating-diffs", "weight": 60 },
      { "name": "formatting-output", "weight": 20 }
    ]
  },
  "config": {
    "tier": "balanced",
    "temperature": 1,
    "maxSteps": 10,
    "maxTokens": 8192,
    "timeout": 120000,
    "executionMode": "durable",
    "durability": {
      "enabled": true,
      "maxDurationMs": 600000,
      "retry": {
        "maxAttempts": 3,
        "backoffMs": 1000,
        "backoffMultiplier": 2
      },
      "checkpointStrategy": "step"
    }
  }
}
